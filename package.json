{
  "name": "iobroker.faut",
  "version": "0.0.1",
  "description": "iobroker faut adapter",
  "author": {
    "name": "NewXtSI",
    "email": "leerzeichen32@googlemail.com"
  },
  "homepage": "https://github.com/NewXtSI/ioBroker.faut",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "faut",
    "automation",
    "IoT"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/NewXtSI/ioBroker.faut.git"
  },
  "engines": {
    "node": ">= 20"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.4.1"
  },
  "devDependencies": {
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "@mui/icons-material": "^5.0.0",
    "@mui/material": "^5.0.0",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node20": "^20.1.9",
    "@types/iobroker": "npm:@iobroker/types@^7.2.2",
    "@types/node": "^20.19.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.5",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "source-map-support": "^0.5.21",
    "typescript": "~5.9.3",
    "vite": "^5.0.0"
  },
  "main": "build/main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "admin/build/",
    "build/",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "node -e \"const{rmSync}=require('fs');['build','admin/build'].forEach(d=>{try{rmSync(d,{recursive:true,force:true})}catch(e){}})\"",
    "build": "npm run build:ts && npm run build:react",
    "build:ts": "tsc -p tsconfig.build.json",
    "watch:ts": "tsc -p tsconfig.build.json --watch",
    "build:react": "vite build --config admin/vite.config.ts",
    "watch:react": "vite build --config admin/vite.config.ts --watch",
    "dev:react": "vite --config admin/vite.config.ts",
    "test:package": "mocha test/package --exit",
    "test": "npm run test:package",
    "check": "tsc --noEmit",
    "lint": "eslint ."
  },
  "bugs": {
    "url": "https://github.com/NewXtSI/ioBroker.faut/issues"
  },
  "readmeFilename": "README.md"
}
