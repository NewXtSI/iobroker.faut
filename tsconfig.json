// Root tsconfig – controls editor support for all TS files.
// Compilation is configured in tsconfig.build.json.
{
	"extends": "@tsconfig/node20/tsconfig.json",
	"compilerOptions": {
		"noEmit": true,
		"allowJs": true,
		"checkJs": true,
		"noEmitOnError": true,
		"outDir": "./build/",
		"removeComments": false,
		"resolveJsonModule": true,
		"sourceMap": true,
		"inlineSourceMap": false
	},
	"include": [
		"src/**/*.ts",
		"test/**/*.ts"
	],
	"exclude": [
		"build/**",
		"node_modules/**"
	]
}
