// Specialized tsconfig for the admin directory –
// type-checking only; Vite handles the actual compilation.
{
	"extends": "../tsconfig.json",
	"compilerOptions": {
		"noEmit": true,
		"noImplicitAny": false,
		"lib": [
			"es2020",
			"DOM",
			"DOM.Iterable"
		],
		"jsx": "react-jsx",
		"module": "ESNext",
		"moduleResolution": "bundler"
	},
	"include": [
		"./**/*.ts",
		"./**/*.tsx",
		"../src/lib/adapter-config.d.ts"
	],
	"exclude": [
		"./**/*.test.ts",
		"./**/*.test.tsx"
	]
}
